---
const games = [
  {
    title: 'R0D3nt',
    image: '/assets/projects/rodent.svg',
    desc: 'A platformer where the odds are deliberately unfair — too many enemies to fight head-on. Survive by leading them into traps and off ledges instead.',
    stack: ['Phaser 2', 'JavaScript'],
    github: 'https://github.com/tuskat/r0d3nt',
    itch: 'https://tuskat.itch.io',
  },
  {
    title: "Teddy's Crew",
    image: '/assets/projects/teddys-crew.svg',
    desc: 'Top-down arcade shooter with endless mob waves and deliberately simple controls. Built on Phaser 3 with a Vue.js interface layer.',
    stack: ['Phaser 3', 'TypeScript', 'Vue.js'],
    github: 'https://github.com/tuskat/teddys-crew',
    itch: 'https://tuskat.itch.io',
  },
  {
    title: 'Road to Dakar',
    image: '/assets/projects/road-to-dakar.svg',
    desc: 'An endless racer inspired by Outrun, but with proper 3D terrain and real car physics — not a side-scroller sliding on a single axis.',
    stack: ['Unity', 'C#'],
    github: 'https://github.com/tuskat/road-to-dakar',
    itch: 'https://tuskat.itch.io',
  },
];
---

<section id="projects">
  <div class="section-wrap">
    <div class="section-title">Projects</div>
    <hr class="div" />

    <!-- Professional -->
    <div class="featured reveal">
      <img src="/assets/projects/expressvpn.svg" alt="ExpressVPN" class="featured-img" width="800" height="450" />
      <div class="featured-body">
        <div class="card-tags">
          <span class="tag">Professional</span>
          <span class="tag tag-nda">NDA</span>
        </div>
        <h3>ExpressVPN Web Estate</h3>
        <p>10+ years of continuous work on one of the world's largest VPN providers. Customer landing pages, internal CMS, framework migrations from Rails through multiple generations of React, router firmware UI, and a browser-based password manager extension. Projects credited with driving hundreds of thousands in revenue impact.</p>
        <div class="stack-row">
          {['Ruby on Rails', 'Vue.js', 'React', 'Angular', 'TypeScript', 'Node.js', 'Astro'].map(s => <span class="chip">{s}</span>)}
        </div>
      </div>
    </div>

    <!-- Games -->
    <div class="sub-title reveal">Games — <a href="https://tuskat.itch.io" target="_blank">tuskat.itch.io</a></div>
    <div class="cards">
      {games.map(g => (
        <div class="card reveal">
          <img src={g.image} alt={g.title} class="card-img" width="800" height="450" />
          <div class="card-body">
            <div class="card-tags">
              <span class="tag">Game</span>
            </div>
            <h3>{g.title}</h3>
            <p>{g.desc}</p>
            <div class="stack-row">
              {g.stack.map(s => <span class="chip">{s}</span>)}
            </div>
            <div class="card-links">
              <a href={g.github} target="_blank">GitHub ↗</a>
              <a href={g.itch} target="_blank">itch.io ↗</a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- OttlerStudio -->
    <div class="sub-title reveal">Studio — <a href="https://ottlerstudio.com" target="_blank">ottlerstudio.com</a></div>
    <div class="featured reveal">
      <img src="/assets/projects/ottlerstudio.svg" alt="OttlerStudio" class="featured-img" width="800" height="450" />
      <div class="featured-body">
        <div class="card-tags">
          <span class="tag">Mobile</span>
          <span class="tag tag-wip">WIP</span>
        </div>
        <h3>OttlerStudio</h3>
        <p>A collection of single-purpose utility apps built with a friend — Password Generator, Cooking Timer, Flashlight, and more. The premise: do one thing, do it with better UX than what's already on the market. Currently in development; store release pending.</p>
        <div class="stack-row">
          {['Flutter', 'Dart'].map(s => <span class="chip">{s}</span>)}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  section {
    padding: 100px 0;
    background: var(--bg);
  }
  .sub-title {
    font-size: 15px;
    color: var(--text3);
    letter-spacing: 0.5px;
    margin-bottom: 20px;
    margin-top: 56px;
  }
  .sub-title a { color: var(--teal); }

  /* Featured card */
  .featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg2);
  }
  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .featured-body {
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Game cards grid */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .card {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg2);
    display: flex;
    flex-direction: column;
  }
  .card-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }
  .card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  /* Shared */
  .card-tags { display: flex; gap: 8px; }
  .tag {
    font-size: 11px;
    padding: 2px 10px;
    border-radius: 20px;
    border: 1px solid var(--border);
    color: var(--text3);
    letter-spacing: 0.5px;
  }
  .tag-nda { border-color: rgba(255,100,100,0.3); color: rgba(255,120,120,0.8); }
  .tag-wip { border-color: rgba(255,180,50,0.3); color: rgba(255,180,50,0.8); }

  h3 { font-size: 18px; font-weight: 500; color: var(--text); }
  p { font-size: 14px; color: var(--text2); line-height: 1.7; }

  .stack-row { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; }
  .chip {
    font-size: 12px;
    color: var(--text3);
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 2px 8px;
  }

  .card-links {
    display: flex;
    gap: 16px;
    margin-top: 4px;
  }
  .card-links a { font-size: 13px; color: var(--teal); }

  @media (max-width: 750px) {
    .featured { grid-template-columns: 1fr; }
    .cards { grid-template-columns: 1fr; }
  }
</style>
