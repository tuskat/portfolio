---
import { en, fr } from '../i18n';

const games = [
  { key: 'rodent',      image: '/assets/projects/r0d3nt.png',       github: 'https://github.com/tuskat/r0d3nt',       itch: 'https://tuskat.itch.io/r0d3nt' },
  { key: 'teddysCrew', image: '/assets/projects/teddys-crew.png',  github: 'https://github.com/tuskat/teddys-crew',  itch: 'https://tuskat.itch.io/teddys-crew' },
  { key: 'roadToDakar',image: '/assets/projects/road-to-dakar.png',github: 'https://github.com/tuskat/RTD',itch: 'https://tuskat.itch.io/road-to-dakar' },
] as const;
---

<section id="projects">
  <div class="section-wrap">
    <div class="section-title">
      <span class="lang-en">{en.projects.title}</span>
      <span class="lang-fr">{fr.projects.title}</span>
    </div>
    <hr class="div" />

    <!-- Professional -->
    <div class="featured featured-noimg reveal">
      <div class="featured-body">
        <div class="card-tags">
          <span class="tag"><span class="lang-en">{en.projects.tags.professional}</span><span class="lang-fr">{fr.projects.tags.professional}</span></span>
          <span class="tag tag-nda">{en.projects.tags.nda}</span>
        </div>
        <h3>{en.projects.expressvpn.title}</h3>
        <p>
          <span class="lang-en">{en.projects.expressvpn.desc}</span>
          <span class="lang-fr">{fr.projects.expressvpn.desc}</span>
        </p>
        <div class="stack-row">
          {['Ruby on Rails', 'Vue.js', 'React', 'Angular', 'TypeScript', 'Node.js', 'Astro'].map(s => <span class="chip">{s}</span>)}
        </div>
      </div>
    </div>

    <!-- Brise -->
    <div class="sub-title reveal">
      <span class="lang-en">{en.projects.openSourceLabel}</span>
      <span class="lang-fr">{fr.projects.openSourceLabel}</span>
      {' '}<a href="https://github.com/tuskat/brise" target="_blank">github.com/tuskat/brise</a>
    </div>
    <div class="brise-card reveal">
      <img src="/assets/projects/brise-dashboard.png" alt="Brise" class="brise-img" width="1200" height="675" />
      <div class="featured-body">
        <div class="card-tags">
          <span class="tag">Open Source</span>
        </div>
        <h3>{en.projects.brise.title}</h3>
        <p>
          <span class="lang-en">{en.projects.brise.desc}</span>
          <span class="lang-fr">{fr.projects.brise.desc}</span>
        </p>
        <div class="stack-row">
          {['Astro', 'Node.js', 'SQLite', 'JavaScript', 'Docker'].map(s => <span class="chip">{s}</span>)}
        </div>
      </div>
    </div>

    <!-- Games -->
    <div class="sub-title reveal">
      <span class="lang-en">{en.projects.gamesLabel}</span>
      <span class="lang-fr">{fr.projects.gamesLabel}</span>
      {' '}<a href="https://tuskat.itch.io" target="_blank">tuskat.itch.io</a>
    </div>
    <div class="cards">
      {games.map(g => {
        const eData = en.projects[g.key];
        const fData = fr.projects[g.key];
        return (
          <div class="card reveal">
            <img src={g.image} alt={eData.title} class="card-img" width="800" height="450" />
            <div class="card-body">
              <div class="card-tags">
                <span class="tag"><span class="lang-en">{en.projects.tags.game}</span><span class="lang-fr">{fr.projects.tags.game}</span></span>
              </div>
              <h3>{eData.title}</h3>
              <p>
                <span class="lang-en">{eData.desc}</span>
                <span class="lang-fr">{fData.desc}</span>
              </p>
              <div class="card-links">
                <a href={g.github} target="_blank">
                  <span class="lang-en">{en.projects.linkGithub}</span>
                  <span class="lang-fr">{fr.projects.linkGithub}</span>
                </a>
                <a href={g.itch} target="_blank">
                  <span class="lang-en">{en.projects.linkItch}</span>
                  <span class="lang-fr">{fr.projects.linkItch}</span>
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- OttlerStudio -->
    <div class="sub-title reveal">
      <span class="lang-en">{en.projects.studioLabel}</span>
      <span class="lang-fr">{fr.projects.studioLabel}</span>
      {' '}<a href="https://ottlerstudio.com" target="_blank">ottlerstudio.com</a>
    </div>
    <div class="featured reveal">
      <img src="/assets/projects/ottlerstudio.png" alt="OttlerStudio" class="featured-img" width="800" height="450" />
      <div class="featured-body">
        <div class="card-tags">
          <span class="tag"><span class="lang-en">{en.projects.tags.mobile}</span><span class="lang-fr">{fr.projects.tags.mobile}</span></span>
          <span class="tag tag-wip"><span class="lang-en">{en.projects.tags.wip}</span><span class="lang-fr">{fr.projects.tags.wip}</span></span>
        </div>
        <h3>{en.projects.ottlerstudio.title}</h3>
        <p>
          <span class="lang-en">{en.projects.ottlerstudio.desc}</span>
          <span class="lang-fr">{fr.projects.ottlerstudio.desc}</span>
        </p>
        <div class="stack-row">
          {['Flutter', 'Dart'].map(s => <span class="chip">{s}</span>)}
        </div>
      </div>
    </div>

  </div>
  <div class="wave">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="var(--bg2)"/>
    </svg>
  </div>
</section>

<style>
  section { padding: 100px 0 0; background: var(--bg); position: relative; }
  .section-wrap { padding-bottom: 120px; }
  .wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 120px;
    pointer-events: none;
  }
  .wave svg { width: 100%; height: 100%; }

  .sub-title {
    font-size: 15px;
    color: var(--text3);
    letter-spacing: 0.5px;
    margin-bottom: 20px;
    margin-top: 56px;
  }
  .sub-title a { color: var(--teal); }

  .featured-noimg { grid-template-columns: 1fr !important; }
  .featured-noimg .featured-body { max-width: 640px; }
  .brise-card {
    display: grid;
    grid-template-columns: 45fr 55fr;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg2);
  }
  .brise-img { width: 100%; height: 100%; object-fit: cover; display: block; object-position: top left; }

  .featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg2);
  }
  .featured-img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .featured-body { padding: 32px 28px; display: flex; flex-direction: column; gap: 14px; }

  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .card {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg2);
    display: flex;
    flex-direction: column;
  }
  .card-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
  .card-body { padding: 20px; display: flex; flex-direction: column; gap: 10px; flex: 1; }

  .card-tags { display: flex; gap: 8px; }
  .tag {
    font-size: 11px;
    padding: 2px 10px;
    border-radius: 20px;
    border: 1px solid var(--border);
    color: var(--text3);
    letter-spacing: 0.5px;
  }
  .tag-nda { border-color: rgba(255,100,100,0.3); color: rgba(255,120,120,0.8); }
  .tag-wip { border-color: rgba(255,180,50,0.3); color: rgba(255,180,50,0.8); }

  h3 { font-size: 18px; font-weight: 500; color: var(--text); }
  p { font-size: 14px; color: var(--text2); line-height: 1.7; }

  .stack-row { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; }
  .chip {
    font-size: 12px;
    color: var(--text3);
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 2px 8px;
  }

  .card-links { display: flex; gap: 16px; margin-top: 4px; }
  .card-links a { font-size: 13px; color: var(--teal); }

  @media (max-width: 750px) {
    .featured { grid-template-columns: 1fr; }
    .cards { grid-template-columns: 1fr; }
  }
</style>
