---
import { en, fr } from '../i18n';

const dates = [
  { en: 'Jan 2025 – Present',       fr: 'Jan 2025 – Présent',     location: 'Madrid · Remote' },
  { en: 'Jul 2017 – Dec 2024',      fr: 'Juil 2017 – Déc 2024',  location: 'Hong Kong · Hybrid' },
  { en: 'Sep 2016 – May 2017',      fr: 'Sep 2016 – Mai 2017',   location: 'Hong Kong' },
  { en: 'Feb – Jul 2016',           fr: 'Fév – Juil 2016',       location: 'Hong Kong' },
];

const stacks = [
  'Vue.js · Astro · TypeScript · Node.js',
  'Ruby on Rails · Vue.js · React · Angular · TypeScript · Node.js',
  'Angular 2 · Node.js · .NET Core MVC · Sass',
  'React · Node.js · Express.js · jQuery',
];
---

<section id="work">
  <div class="section-wrap">
    <div class="section-title">
      <span class="lang-en">{en.work.title}</span>
      <span class="lang-fr">{fr.work.title}</span>
    </div>
    <hr class="div" />

    <div class="jobs">
      {en.work.jobs.map((job, i) => (
        <div class="job reveal">
          <div class="job-meta">
            <span class="job-dates">
              <span class="lang-en">{dates[i].en}</span>
              <span class="lang-fr">{dates[i].fr}</span>
            </span>
            <span class="job-location">{dates[i].location}</span>
          </div>
          <div class="job-body">
            <div class="job-company">
              <span class="lang-en">{job.company}</span>
              <span class="lang-fr">{fr.work.jobs[i].company}</span>
              {job.client && <span class="job-client"> · {job.client}</span>}
              {job.desc && (
                <span class="job-desc">
                  {' · '}<span class="lang-en">{job.desc}</span>
                  <span class="lang-fr">{fr.work.jobs[i].desc}</span>
                </span>
              )}
            </div>
            <div class="job-role">
              <span class="lang-en">{job.role}</span>
              <span class="lang-fr">{fr.work.jobs[i].role}</span>
            </div>
            <div class="job-stack">{stacks[i]}</div>
            {job.bullets.length > 0 && (
              <ul class="job-bullets">
                {job.bullets.map((bullet, b) => (
                  <li>
                    <span class="lang-en">{bullet}</span>
                    <span class="lang-fr">{fr.work.jobs[i].bullets[b]}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
  <div class="wave">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="var(--bg)"/>
    </svg>
  </div>
</section>

<style>
  section {
    padding: 100px 0 0;
    background: var(--bg2);
    position: relative;
  }
  .section-wrap { padding-bottom: 120px; }
  .wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 120px;
    pointer-events: none;
  }
  .wave svg { width: 100%; height: 100%; }
  .jobs { display: flex; flex-direction: column; }

  .job {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 0.5px solid var(--border);
  }
  .job:last-child { border-bottom: none; }

  .job-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 3px;
  }
  .job-dates { font-size: 13px; color: var(--text3); }
  .job-location { font-size: 12px; color: var(--text3); }

  .job-company {
    font-size: 18px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 2px;
  }
  .job-client { color: var(--teal); font-weight: 400; }
  .job-desc { font-weight: 400; color: var(--text3); font-size: 14px; }
  .job-role { font-size: 14px; color: var(--text2); font-style: italic; margin-bottom: 6px; }
  .job-stack { font-size: 12px; color: var(--text3); margin-bottom: 10px; }

  .job-bullets {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .job-bullets li {
    font-size: 14px;
    color: var(--text2);
    padding-left: 14px;
    position: relative;
  }
  .job-bullets li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--teal);
  }

  @media (max-width: 600px) {
    .job { grid-template-columns: 1fr; gap: 8px; }
  }
</style>
