---
---

<section id="work">
  <div class="section-wrap">
    <div class="section-title">Experience</div>
    <hr class="div" />

    <div class="jobs">

      <div class="job reveal">
        <div class="job-meta">
          <span class="job-dates">Jan 2025 – Present</span>
          <span class="job-location">Madrid · Remote</span>
        </div>
        <div class="job-body">
          <div class="job-company">Self-employed <span class="job-client">· ExpressVPN</span></div>
          <div class="job-role">Senior Frontend Developer</div>
          <div class="job-stack">Vue.js · Astro · TypeScript · Node.js</div>
          <ul class="job-bullets">
            <li>Maintained and stabilised the Rails codebase as the team's primary Rails resource</li>
            <li>Resolved breaking issues and content-critical fixes across live customer-facing pages</li>
            <li>Contributed to the migration toward a Next.js architecture</li>
          </ul>
        </div>
      </div>

      <div class="job reveal">
        <div class="job-meta">
          <span class="job-dates">Jul 2017 – Dec 2024</span>
          <span class="job-location">Hong Kong · Hybrid</span>
        </div>
        <div class="job-body">
          <div class="job-company">Network Guard <span class="job-desc">· contractor to ExpressVPN</span></div>
          <div class="job-role">Senior Frontend Developer · Full-time</div>
          <div class="job-stack">Ruby on Rails · Vue.js · React · Angular · TypeScript · Node.js</div>
          <ul class="job-bullets">
            <li>Led the V2 UI overhaul of a physical router firmware product (Vue.js)</li>
            <li>Led multiple Rails-to-React migration cycles on ExpressVPN's customer-facing pages</li>
            <li>Contributed to a browser-based password manager extension</li>
            <li>Contributed to projects credited with driving or saving hundreds of thousands of dollars in revenue</li>
            <li>Migrated translation management system from Phrase to Crowdin across the full product</li>
          </ul>
        </div>
      </div>

      <div class="job reveal">
        <div class="job-meta">
          <span class="job-dates">Sep 2016 – May 2017</span>
          <span class="job-location">Hong Kong</span>
        </div>
        <div class="job-body">
          <div class="job-company">NLS <span class="job-desc">· placed at FLO Capital</span></div>
          <div class="job-role">Frontend Developer</div>
          <div class="job-stack">Angular 2 · Node.js · .NET Core MVC · Sass</div>
          <ul class="job-bullets">
            <li>Built the investor-facing frontend for a private equity crowdfunding platform</li>
          </ul>
        </div>
      </div>

      <div class="job reveal">
        <div class="job-meta">
          <span class="job-dates">Feb – Jul 2016</span>
          <span class="job-location">Hong Kong</span>
        </div>
        <div class="job-body">
          <div class="job-company">Intralogue <span class="job-desc">· collaborative workspace startup</span></div>
          <div class="job-role">Frontend Developer</div>
          <div class="job-stack">React · Node.js · Express.js · jQuery</div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  section {
    padding: 100px 0 80px;
    background: var(--bg2);
  }
  .jobs { display: flex; flex-direction: column; gap: 0; }

  .job {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 0.5px solid var(--border);
  }
  .job:last-child { border-bottom: none; }

  .job-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 3px;
  }
  .job-dates { font-size: 13px; color: var(--text3); }
  .job-location { font-size: 12px; color: var(--text3); }

  .job-company {
    font-size: 18px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 2px;
  }
  .job-client { font-weight: 400; color: var(--teal); }
  .job-desc { font-weight: 400; color: var(--text3); font-size: 14px; }
  .job-role { font-size: 14px; color: var(--text2); font-style: italic; margin-bottom: 6px; }
  .job-stack { font-size: 12px; color: var(--text3); margin-bottom: 10px; letter-spacing: 0.2px; }

  .job-bullets {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .job-bullets li {
    font-size: 14px;
    color: var(--text2);
    padding-left: 14px;
    position: relative;
  }
  .job-bullets li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--teal);
  }

  @media (max-width: 600px) {
    .job { grid-template-columns: 1fr; gap: 8px; }
  }
</style>
