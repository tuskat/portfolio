---
import { en, fr } from '../i18n';
---

<nav id="nav">
  <div class="nav-inner">
    <a class="nav-name" href="#">CM</a>
    <ul class="nav-links">
      <li><a href="#work"><span class="lang-en">{en.nav.work}</span><span class="lang-fr">{fr.nav.work}</span></a></li>
       <li><a href="#projects"><span class="lang-en">{en.nav.projects}</span><span class="lang-fr">{fr.nav.projects}</span></a></li>
      <li><a href="#testimonials"><span class="lang-en">{en.nav.testimonials}</span><span class="lang-fr">{fr.nav.testimonials}</span></a></li>
      <li><a href="#about"><span class="lang-en">{en.nav.about}</span><span class="lang-fr">{fr.nav.about}</span></a></li>
      <li><a href="#contact"><span class="lang-en">{en.nav.contact}</span><span class="lang-fr">{fr.nav.contact}</span></a></li>
    </ul>
    <div class="nav-right">
      <div class="lang-toggle">
        <button id="btn-en" class="lang-btn active" onclick="setLang('en')">EN</button>
        <button id="btn-fr" class="lang-btn" onclick="setLang('fr')">FR</button>
      </div>
      <a class="nav-cv" href="/assets/cedric_marcellin_cv_light.pdf" target="_blank">
        <span class="lang-en">{en.nav.downloadCV}</span>
        <span class="lang-fr">{fr.nav.downloadCV}</span>
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav')!;
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  function setLang(lang: string) {
    document.body.classList.remove('lang-en', 'lang-fr');
    document.body.classList.add('lang-' + lang);
    document.getElementById('btn-en')!.classList.toggle('active', lang === 'en');
    document.getElementById('btn-fr')!.classList.toggle('active', lang === 'fr');
    document.documentElement.lang = lang;
    sessionStorage.setItem('lang', lang);
  }

  // Expose globally for inline onclick
  (window as any).setLang = setLang;

  // Restore saved preference
  const saved = sessionStorage.getItem('lang');
  if (saved === 'fr') setLang('fr');
</script>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    transition: background 0.3s, backdrop-filter 0.3s, border-color 0.3s;
    border-bottom: 1px solid transparent;
  }
  nav.scrolled {
    background: rgba(42,42,40,0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-color: var(--border);
  }
  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 32px;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .nav-name {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--teal);
    text-decoration: none;
    margin-right: auto;
  }
  .nav-links {
    list-style: none;
    display: flex;
    gap: 28px;
  }
  .nav-links a {
    font-size: 14px;
    color: var(--text2);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); opacity: 1; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .lang-toggle {
    display: flex;
    gap: 2px;
  }
  .lang-btn {
    background: transparent;
    border: 1px solid transparent;
    color: var(--text3);
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    padding: 3px 8px;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.5px;
  }
  .lang-btn:hover { color: var(--text2); }
  .lang-btn.active {
    color: var(--teal);
    border-color: rgba(59,191,160,0.3);
  }

  .nav-cv {
    font-size: 13px;
    padding: 6px 16px;
    border: 1px solid var(--teal);
    border-radius: 4px;
    color: var(--teal);
    text-decoration: none;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .nav-cv:hover { background: var(--teal-dim); opacity: 1; }

  @media (max-width: 700px) {
    .nav-links { display: none; }
  }
</style>
