---
const groups = [
  {
    label: 'Frontend',
    skills: ['JavaScript', 'TypeScript', 'Vue.js', 'React', 'Angular', 'Astro', 'Sass / CSS'],
  },
  {
    label: 'Backend',
    skills: ['Ruby on Rails', 'Node.js', 'Express.js', '.NET Core'],
  },
  {
    label: 'Mobile & Other',
    skills: ['Flutter', 'Unity / C#', 'Phaser (2 & 3)'],
  },
  {
    label: 'Tools',
    skills: ['Git', 'REST APIs', 'Crowdin', 'Puppeteer', 'Figma'],
  },
];
---

<section id="skills">
  <div class="section-wrap">
    <div class="section-title reveal">Skills</div>
    <hr class="div" />
    <div class="groups">
      {groups.map(g => (
        <div class="group reveal">
          <div class="group-label">{g.label}</div>
          <div class="chips">
            {g.skills.map(s => <span class="chip">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 80px 0;
    background: var(--bg2);
  }
  .groups {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .group {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 16px;
    align-items: start;
  }
  .group-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--text3);
    letter-spacing: 0.5px;
    padding-top: 6px;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chip {
    font-size: 14px;
    color: var(--text);
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 4px 12px;
  }

  @media (max-width: 600px) {
    .group { grid-template-columns: 1fr; gap: 8px; }
  }
</style>
