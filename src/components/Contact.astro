---
const links = [
  { label: 'Email', value: 'cedric.marcellin@gmail.com', href: 'mailto:cedric.marcellin@gmail.com' },
  { label: 'LinkedIn', value: 'cedric-marcellin', href: 'https://www.linkedin.com/in/cedric-marcellin-70317889/' },
  { label: 'GitHub', value: 'github.com/tuskat', href: 'https://github.com/tuskat' },
  { label: 'Illustration', value: 'cara.app/tuskat', href: 'https://cara.app/tuskat' },
  { label: 'Games', value: 'tuskat.itch.io', href: 'https://tuskat.itch.io' },
  { label: 'Studio', value: 'ottlerstudio.com', href: 'https://ottlerstudio.com' },
];
---

<section id="contact">
  <div class="section-wrap">
    <div class="section-title reveal">Contact</div>
    <hr class="div" />
    <p class="intro reveal">No forms. Just pick your preferred channel.</p>
    <div class="links reveal">
      {links.map(l => (
        <a class="link-row" href={l.href} target={l.href.startsWith('mailto') ? undefined : '_blank'}>
          <span class="link-label">{l.label}</span>
          <span class="link-value">{l.value}</span>
          <span class="link-arrow">↗</span>
        </a>
      ))}
    </div>
  </div>

  <p class="meta reveal">
    This portfolio and CV were built in plain HTML/CSS and Astro — no templates. The CV exports to pixel-perfect PDF via a Puppeteer pipeline. Iterated with Claude Code. <a href="https://github.com/tuskat" target="_blank">Source ↗</a>
  </p>

  <div class="bottom-bar"></div>
</section>

<style>
  section {
    padding: 100px 0 0;
    background: var(--bg);
    position: relative;
  }
  .intro {
    font-size: 16px;
    color: var(--text3);
    margin-bottom: 32px;
  }
  .links {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 80px;
  }
  .link-row {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 16px 0;
    border-bottom: 0.5px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: background 0.15s;
  }
  .link-row:hover { opacity: 1; }
  .link-row:hover .link-label { color: var(--teal); }
  .link-row:hover .link-arrow { opacity: 1; }
  .link-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--text3);
    letter-spacing: 0.5px;
    width: 100px;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .link-value {
    font-size: 16px;
    color: var(--text);
    flex: 1;
  }
  .link-arrow {
    font-size: 16px;
    color: var(--teal);
    opacity: 0;
    transition: opacity 0.15s;
  }

  .meta {
    max-width: 900px;
    margin: 0 auto 48px;
    padding: 0 32px;
    font-size: 13px;
    color: var(--text3);
    line-height: 1.6;
  }
  .meta a { color: var(--text3); text-decoration: underline; text-underline-offset: 3px; }
  .meta a:hover { color: var(--teal); opacity: 1; }

  .bottom-bar {
    background: var(--teal);
    height: 14px;
  }
</style>
